{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh repo view *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(openssl rand *)",
      "Skill(update-config)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(alembic *)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)",
      "Bash(openssl *)",
      "Bash(curl *)",
      "Bash(chmod *)",
      "Bash(DYLD_LIBRARY_PATH=* *)",
      "Bash(DATABASE_URL=* *)",
      "Bash(./scripts/*.sh *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(ssh *)",
      "Bash(curl * | bash *)",
      "Bash(wget * | bash *)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "team-harness": {
      "source": {
        "source": "github",
        "repo": "grinvi04/team-harness"
      }
    }
  },
  "enabledPlugins": {
    "harness-guard@team-harness": true,
    "security-guidance@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh",
            "timeout": 10,
            "statusMessage": "세션 컨텍스트 로딩 중..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-dangerous.sh",
            "timeout": 10,
            "statusMessage": "위험 명령 검사 중..."
          },
          {
            "type": "prompt",
            "timeout": 15,
            "prompt": "아래 Bash 명령어가 Alembic 마이그레이션을 2단계 이상 되돌리거나(예: downgrade -2, downgrade -3, downgrade <해시>), DB 스키마를 대량으로 파괴할 위험이 있으면 deny하라. 단 'alembic downgrade -1'은 반드시 allow한다. 명령어: $ARGUMENTS.tool_input.command. JSON으로만 응답: {\"decision\": \"allow\" 또는 \"deny\", \"reason\": \"deny 시 이유\"}"
          },
          {
            "type": "prompt",
            "timeout": 15,
            "prompt": "아래 Bash 명령어가 .env 파일이나 환경변수에 담긴 시크릿(DB 비밀번호, API 키, 토큰 등)을 외부 URL로 전송하거나 터미널 밖으로 노출할 위험이 있으면 deny하라. 단순히 .env를 읽거나 환경변수를 로컬에서 사용하는 것은 allow한다. 명령어: $ARGUMENTS.tool_input.command. JSON으로만 응답: {\"decision\": \"allow\" 또는 \"deny\", \"reason\": \"deny 시 이유\"}"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/validate-edit.sh",
            "timeout": 120,
            "statusMessage": "코드 검증 중 (lint · 타입 · 테스트)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
